# Secrets — never commit real API keys
.env

# Local database is force-added for deploy (catalog ships with the repo).
# It stays listed here so day-to-day local writes don't show up as changes;
# the initial deploy commit adds it with `git add -f screamstream.db`.
screamstream.db
users.db

# Big IMDb dataset dumps (hundreds of MB) — regenerated by import_imdb.py
.imdb_cache/
*.part

# backfill_posters.py local state: IMDb ids OMDb had no poster for (skip on rerun)
.poster_misses.txt

# Logs / editor / caches
*.log
.vscode/
.expo/
__pycache__/
*.pyc
