# Copy this file to ".env" and fill in your keys, then restart: python app.py
# The .env file is gitignored — your keys stay private.

# Required for AI search + the big TMDB catalog (free): https://www.themoviedb.org/settings/api
# Use the v3 "API Key" (the ~32-char string), NOT the "API Read Access Token".
TMDB_API_KEY=

# "Ask anything about movies" — free LLM (no credit card) that writes
# audience-consensus answers: https://console.groq.com -> API Keys.
GROQ_API_KEY=
# Optional model override (default llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — real IMDb + Rotten Tomatoes scores (free): https://www.omdbapi.com/apikey.aspx
# This is the main TMDB replacement when TMDB is blocked in your region:
# poster, plot, cast, IMDb + Rotten Tomatoes + Metacritic, MPAA, runtime.
OMDB_API_KEY=

# Optional — real trailers when TMDB is blocked (free).
# Google Cloud Console -> enable "YouTube Data API v3" -> Credentials -> API key.
# Note: search costs 100 quota units/call; the free 10,000/day = ~100 new
# titles enriched per day (each is cached after first view).
YOUTUBE_API_KEY=

# Optional — region-accurate "where to watch" when TMDB is blocked (free tier).
# Subscribe (free) to the Streaming Availability API, then copy your RapidAPI key:
# https://rapidapi.com/movie-of-the-night-movie-of-the-night-default/api/streaming-availability
RAPIDAPI_KEY=

# Optional — 2-letter country for "where to watch" (default IN)
TMDB_REGION=IN

# The single admin account — the username you put here gets the Admin panel;
# everyone else is always a customer (regardless of signup order). Pick your own.
ADMIN_USERNAME=

# Optional — set a real secret for sessions in production
# SECRET_KEY=change-me
